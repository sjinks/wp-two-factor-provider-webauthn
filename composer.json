{
	"name": "wildwolf/two-factor-provider-webauthn",
	"type": "wordpress-plugin",
	"description": "WebAuthn provider for Two Factor WordPress plugin",
	"autoload": {
		"classmap": [
			"inc/"
		]
	},
	"repositories": [
		{
			"name": "wpackagist",
			"type": "composer",
			"url": "https://wpackagist.org",
			"only": [
				"wpackagist-plugin/*",
				"wpackagist-theme/*"
			]
		}
	],
	"require": {
		"php": "^8.0.0",
		"composer/installers": "^2.0",
		"cweagans/composer-patches": "^2.0",
		"madwizard/webauthn": "^1.0.0",
		"typisttech/imposter-plugin": "^0.6.2",
		"wildwolf/singleton-trait": "^1.0"
	},
	"require-dev": {
		"automattic/vipwpcs": "^3.0",
		"johnpbloch/wordpress-core": "^6.0",
		"php-stubs/wordpress-stubs": "^6.0",
		"phpcompatibility/phpcompatibility-wp": "^2.1",
		"phpunit/php-code-coverage": "^9.2",
		"wildwolf/wordpress-test-library-stubs": "^6.0",
		"wp-cli/i18n-command": "^2.2",
		"wp-phpunit/wp-phpunit": "^6.0",
		"wpackagist-plugin/two-factor": "^0.16.0"
	},
	"config": {
		"sort-packages": true,
		"allow-plugins": {
			"composer/package-versions-deprecated": true,
			"composer/installers": true,
			"typisttech/imposter-plugin": true,
			"cweagans/composer-patches": true,
			"dealerdirect/phpcodesniffer-composer-installer": true
		},
		"platform": {
			"php": "8.1.31"
		},
		"optimize-autoloader": true,
		"classmap-authoritative": true,
		"autoloader-suffix": "WWTFWA"
	},
	"extra": {
		"imposter": {
			"namespace": "WildWolf\\WordPress\\TwoFactorWebAuthn\\Vendor",
			"excludes": [
				"cweagans/composer-patches",
				"wildwolf/singleton-trait"
			]
		},
		"installer-paths": {
			"vendor/wordpress/{$name}/": [
				"type:wordpress-plugin"
			]
		},
		"patches": {
			"madwizard/webauthn": [
				{
					"description": "Fix interoperability with imposter",
					"url": "patches/webauthn.patch",
					"depth": 0
				},
				{
					"description": "Fix client extension verification (GH-295)",
					"url": "patches/client-extensions.patch",
					"depth": 0
				},
				{
					"description": "Fix EdDSA keys/improve YubiKey support",
					"url": "patches/gh-541.patch",
					"depth": 0
				},
				{
					"description": "Fix Firefox iCloud support",
					"url": "patches/webauthn-icloud.patch",
					"depth": 0
				}
			],
			"guzzlehttp/guzzle": [
				{
					"description": "Fix namespace in check",
					"url": "patches/guzzle.patch",
					"depth": 0
				}
			]
		}
	},
	"scripts": {
		"phpcs": "phpcs",
		"phpcs:fix": "phpcbf",
		"psalm": "psalm --long-progress --no-cache"
	}
}
